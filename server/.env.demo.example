# Hosted demo environment
# Use this for the first investor-safe public POC when storage, real email, and
# Stripe are intentionally deferred. Do not use this mode for real customers.

APP_ENV=demo

# Neon Postgres
# Use Neon's pooled connection string for hosted/serverless runtimes.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/techsync?sslmode=require

# Auth
# Generate a real value and store it in the host secret manager:
# openssl rand -hex 32
JWT_SECRET_KEY=replace-with-host-secret-manager-value

# Hosted public URLs
# Use the deployed portfolio/app origin once it exists.
CORS_ORIGINS=https://your-portfolio-domain.com
APP_BASE_URL=https://your-portfolio-domain.com

# Billing remains in mock/deferred mode while Stripe keys are empty.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://your-portfolio-domain.com/billing/success
STRIPE_CANCEL_URL=https://your-portfolio-domain.com/billing/cancel

# Email remains log/deferred in hosted demo mode.
EMAIL_DELIVERY_METHOD=log
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Attachment storage remains deferred in hosted demo mode.
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=
ATTACHMENT_MAX_BYTES=10485760

# Runtime
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_PROXY_HEADERS=false
LOG_FORMAT=json
